{
    "InitialAdmin": {
        "Email": "admin@example.com",
        "EmployeeId": "admin-001",
        "DisplayName": "Administrator",
        "Hint": "Set 'InitialAdmin:Password' via dotnet user-secrets"
    },
    "Admin": {
        "Hint": "Optional: set 'Admin:DefaultResetPassword' via user-secrets or env var Admin__DefaultResetPassword"
    },
    "ConnectionStrings": {
        "Timecard": "Host=localhost;Port=5432;Database=timecard;Username=devuser;Password=change_me;",
        "Hint": "Set 'ConnectionStrings:Timecard' via dotnet user-secrets or env var ConnectionStrings__Timecard"
    },
    "Serilog": {
        "Using": [ "Serilog.Sinks.Console" ],
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft": "Warning",
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
                "System": "Warning"
            }
        },
        "Enrich": [ "FromLogContext" ],
        "WriteTo": [
            {
                "Name": "Console",
                "Args": {
                    "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {SourceContext} {Message:lj}{NewLine}{Exception}"
                }
            }
        ],
        "Properties": {
            "Application": "Timecard.Api"
        }
    },
    "SyncPunch": {
        "Hint": "Set 'ApiKey' via dotnet user-secrets or env var SyncPunch__ApiKey"
    },
    "CalendarSeed": {
        "Dgpa": {
            "CsvRelativePath": "Seeds/115-dpga-gov-calendar.csv"
        }
    }
}
